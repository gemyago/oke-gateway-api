repo_root=$(expand_path "$PWD/..")
go_version=$(grep "^go " "$repo_root/go.mod" | awk '{print $2}')

gobrew use ${go_version}@latest

export GOPATH=$(expand_path "$repo_root/../go/${go_version}")

PATH_add "$GOPATH/bin"
PATH_add "$repo_root/bin"

export OKE_E2E_NAMESPACE_PREFIX="${OKE_E2E_NAMESPACE_PREFIX:-oke-gw-e2e-}"
export OKE_E2E_GATEWAY_CLASS_NAME="${OKE_E2E_GATEWAY_CLASS_NAME:-oke-gateway-api-e2e}"
export OKE_E2E_HTTP_PORT="${OKE_E2E_HTTP_PORT:-80}"
export OKE_E2E_CONTROLLER_BIN="${OKE_E2E_CONTROLLER_BIN:-../dist/bin/controller}"
export OKE_E2E_SKIP_CONTROLLER_START="${OKE_E2E_SKIP_CONTROLLER_START:-false}"

if [ -d "$repo_root/.venv" ] && [ -f "$repo_root/.venv/bin/activate" ]; then
	source "$repo_root/.venv/bin/activate"
fi

[[ -f .envrc.local ]] && source_env .envrc.local
